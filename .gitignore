# .gitignore: repository allowlist
# see gitignore(5)

# Ignore everything except directories
*
!*/

# Now specify the files we want to track

!/.gitignore
!/.gitmodules

!/README.md

!/*-dotfiles.sh

!/asoundrc

!/alacritty/*.toml
!/alacritty/*.yaml
!/alacritty/*.yml
!/alacritty/colorschemes
!/alacritty/themes

!/bash_completion
!/bash_logout
!/bash_profile
!/bashrc
!/bash_completion.d/**
!/bashrc.d/**

!/bat/config
!/bat/themes/**

!/colors-*.py
!/colorschemes.py
!/colorschemes-*.py
!/colorschemes/*.py
!/colorschemes/*.sh
!/colorschemes/*.toml

!/dircolors

!/environment.d/**

!/foot/*.ini
!/foot/colorschemes

!/fzf/fzfrc
!/fzf/*.bash
!/fzf/*.fish
!/fzf/*.sh
!/fzf/*.zsh

!/git/config
!/git/ignore

!/gnupg/dirmngr.conf
!/gnupg/gpg-agent.conf
!/gnupg/gpg.conf

!/inputrc
!/inputrc.d/**

!/kitty/*.conf
!/kitty/colorschemes
!/kitty/themes

!/launchd/agents/*.plist

!/mcphub/servers.json

!/mpd/mpd.conf

!/ncmpcpp/config

!/noctalia/*.json

!/npmrc

!/nvim/init.vim
!/nvim/init.lua
!/nvim/lua/**

!/ohmyzsh/

!/profile
!/profile.d/**

!/pythonrc.py

!/ranger/*.conf

!/ripgreprc

!/starship.toml
!/starship/**

!/systemd/user/*.service
!/systemd/user/*.socket

!/termux/colorschemes
!/termux/colors.properties
!/termux/termux.properties

!/tmux.conf
!/tmux/tmux.conf
!/tmux/*.conf
!/tmux/*.tmux
!/tmux/colorschemes

!/user-dirs.dirs
!/user-dirs.locale

!/user-tmpfiles.d/**

!/vim/autoload/**
!/vim/colorschemes
!/vim/vimrc

!/vivid/themes/*

!/xinitrc
!/xinitrc.d/*.sh
!/xprofile
!/xserverrc
!/xsession

!/Xresources
!/Xresources.d/**

!/zlogin
!/zlogout
!/zprofile
!/zshenv
!/zshrc

!/yazi/flavors/*/**
!/yazi/plugins/*/**
!/yazi/package.toml
!/yazi/theme.toml

# Vendored / package-manager-managed trees that should never be tracked.
# These are anchored so git stops descending into them and listing the
# directories themselves as untracked.
/superpowers/
/tmux/plugins/
/vim/plug/
/yazi/packages/

# macOS AppleDouble metadata (must come after allowlist negations)
**/._*
