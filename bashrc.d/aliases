#!/usr/bin/env bash
#
# ~/.bash_aliases : aliases for interactive shells

# Record an absolute path to this file (used by add-alias in builtin_extensions).
if  (( __aliases__ ))
then
  [[ $0 != "${BASH_SOURCE[0]}" ]] && return 0 || exit 0
else
  (( __aliases__ = 1 ))
fi


if read -d '' -r BASH_ALIASES_FILE
then
  export BASH_ALIASES_FILE="${BASH_ALIASES_FILE%/}/${BASH_SOURCE[0]##*/}"
else
  unset BASH_ALIASES_FILE
fi < <(CDPATH='' cd -- "${BASH_SOURCE[0]%/*}" && pwd && printf '\0')


# general defaults
alias gdb='gdb -q'
alias mkdir='mkdir -pv'
alias mv='mv -biv'
alias rm='rm -Iv'
alias rmdir='rmdir -v'
alias vim='vim -p'
alias feh='feh -B black -D 7 -Z'

# A trailing space lets the *next* word be alias-expanded too (e.g. `sudo ll`).
# Replaces the old fmtalias helper, which relied on the bash 4.3+ BASH_ALIASES
# array and silently did nothing on the bash 3.2 that ships with macOS.
alias sudo='sudo '
alias nohup='nohup '
alias unbuffer='unbuffer '

# Colorize matching tools (grep accepts --color=auto on both GNU and BSD).
alias grep='grep --color=auto'
alias egrep='egrep --color=auto'
alias fgrep='fgrep --color=auto'

# ls: base flags plus color where supported (GNU --color=auto, else BSD -G).
if ls --color=auto -d . > /dev/null 2>&1; then
  alias ls='ls -Cp --color=auto'
else
  alias ls='ls -CpG'
fi

# go back to the previous directory
alias -- -='cd -'

# clear
alias c='clear'

# dirstack
alias ds='dirs'
alias po='popd'
alias pu='pushd'

# jobs
alias j='jobs'
alias jl='jobs -l'
alias jx='jobs -x'

# thefuck
if command -v fuck 1> /dev/null
then
    alias fk='fuck'
fi

# ls shortcuts
alias l='ls'
alias ll='ls -l'
alias la='ls -A'
alias lla='ls -lA'

# python
alias py='python'
alias py3='python3'
if command -v python3 1> /dev/null
then
  alias python='python3'
fi
if command -v pip3 1> /dev/null
then
  alias pip='pip3'
fi

# systemd
if command -v systemctl 1> /dev/null
then
  alias scl='systemctl'
  alias jcl='journalctl'
  alias sclu='systemctl --user'
  alias jclu='journalctl --user'
fi

# tmux
if command -v tmux 1> /dev/null
then
  alias t='tmux'
  alias ta='tmux attach'
  alias tl='tmux ls'
  alias tn='tmux new'
fi

# top
if command -v htop 1> /dev/null
then
  alias top='htop'
fi

# vim
alias v='vim'

# xclip clipboard helpers
if command -v xclip 1> /dev/null
then
  alias cb='xclip -sel clipboard'
  alias cb-lstrip='cb -o | sed '"'"'s/^[ \t]*//'"'"' | cb'
  alias cb-rstrip='cb -o | sed '"'"'s/[ \t]*$//'"'"' | cb'
  alias cb-strip='cb -o | sed '"'"'s/^[ \t]*\|[ \t]*$//'"'"' | cb'

  alias cb1='xclip -sel primary'
  alias cb1-lstrip='cb1 -o | sed '"'"'s/^[ \t]*//'"'"' | cb1'
  alias cb1-rstrip='cb1 -o | sed '"'"'s/[ \t]*$//'"'"' | cb1'
  alias cb1-strip='cb1 -o | sed '"'"'s/^[ \t]*\|[ \t]*$//'"'"' | cb1'

  alias cb2='xclip -sel secondary'
  alias cb2-lstrip='cb2 -o | sed '"'"'s/^[ \t]*//'"'"' | cb2'
  alias cb2-rstrip='cb2 -o | sed '"'"'s/[ \t]*$//'"'"' | cb2'
  alias cb2-strip='cb2 -o | sed '"'"'s/^[ \t]*\|[ \t]*$//'"'"' | cb2'
fi

# remove a trailing newline from a file (bash 4.3+: uses mapfile and a negative
# subscript, so on the 3.2 floor this errors on call rather than at load)
trim-nl()
{
  local MAPFILE || return

  if ! (( $# ))
  then
    printf 1>&2 'usage: %s file ...\n' "${FUNCNAME[0]}"
    return 2
  fi

  while (( $# ))
  do
    if mapfile <"$1" && [[ ${MAPFILE[-1]:(-1)} == $'\n' ]]
    then
      truncate -s -1 "$1"
    fi
    shift
  done
}

# find non-recursively in the current directory
alias findhere='find . -mindepth 1 -maxdepth 1'

# query DNS servers for my WAN IP
alias wanip='dig @resolver1.opendns.com ANY myip.opendns.com +short'
alias wanip4='dig @resolver1.opendns.com -4 myip.opendns.com +short'
alias wanip6='dig @resolver1.opendns.com -6 myip.opendns.com +short'

